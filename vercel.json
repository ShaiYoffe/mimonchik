{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/assets/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/wp-content/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/s2/:key",
      "destination": "https://leads.ymedia.co.il/api/sales-webhook/:key"
    },
    {
      "source": "/api/s1",
      "destination": "/api/lead-backup"
    }
  ]
}
